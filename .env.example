# Encryption configuration
JWT_SECRET=a_32_character_hexadecimal_string_for_jwt_signing
BOOTSTRAP_SETUP_TOKEN=a_64_character_hexadecimal_string_for_bootstrap_setup
APP_ENCRYPTION_KEY=a_32_character_hexadecimal_string_for_encryption


# Token expiry settings
JWT_EXPIRY_SECONDS=3600
JWT_STREAM_EXPIRY_SECONDS=900
INVITE_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7


# Database credentials
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=audita
DB_HOST=10.0.80.7
DB_PORT=7010
DB_URL=jdbc:postgresql://10.0.80.7:7010/audita


# SMTP configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@audita.io
SMTP_FROM_NAME=Audita
SMTP_AUTH=true
SMTP_TLS=true


# Application settings
APP_BASE_URL=http://localhost:7100
APP_BASE_PATH=/api
APP_INTERNAL_BASE_PATH=http://api:8080
CORS_ALLOWED_ORIGINS=http://localhost:7100
JPA_DDL_AUTO=validate
TRUST_FORWARDED_HEADERS=false
MANAGEMENT_HEALTH_MAIL_ENABLED=false
UPLOAD_MAX_SIZE_BYTES=10485760
UPLOAD_MAX_SIZE=10MB
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
API_BASE_URL=http://localhost:7080
API_INTERNAL_BASE_URL=http://api.audita.internal:8080
FRONTEND_BASE_URL=http://localhost:7100
AUTH_COOKIE_SECURE=false # Set to true in https environments

# Web container environment
NUXT_SETUP_TOKEN=a_64_character_hexadecimal_string_for_bootstrap_setup
AUDIT_EXPORT_STORAGE_PATH=/tmp/uploads/exports

# Logging configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_FLYWAY=INFO
LOG_FILE=/tmp/logs/audita-api.log
LOG_FILE_MAX_SIZE=50MB
LOG_FILE_MAX_HISTORY=30
LOG_FILE_TOTAL_SIZE_CAP=1GB

# AES-256 key (Base64-encoded) for encrypting refresh token cookies.
# Generate: openssl rand 32 | base64
AUDITA_AUTH_REFRESH_COOKIE_ENCRYPTION_KEY=
SPRING_PROFILES_ACTIVE=dev


# Storage configuration (leave S3 config blank if using STORAGE_BACKEND=LOCAL)
STORAGE_BACKEND=LOCAL
STORAGE_LOCAL_BASE_PATH=/tmp/uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=