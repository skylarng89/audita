  "version": "0.0.0",
  "author": {
    "name": "Patrick Aziken",
    "email": "onaziken@gmail.com"
  },
  "description": "Audita web interface",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
